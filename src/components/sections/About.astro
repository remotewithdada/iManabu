---
import Container from "../Container.astro";
import Button from "../Button.astro";
---

<section class="section" id="about" aria-labelledby="about-title">
  <Container>
    <div class="split">
      <div>
        <p class="eyebrow">About iManabu</p>
        <h2 id="about-title">Language lessons built around real communication.</h2>
      </div>
      <div class="prose">
        <p>
          iManabu is an online language school offering Japanese lessons and English lessons
          for students of all ages. We make practical communication approachable through
          clear guidance, patient practice, and a friendly learning environment.
        </p>
        <p>
          Every learner brings a different goal. Our personalized learning approach adapts
          to your level, pace, and needs—whether you are starting from zero, learning practical
          Japanese, preparing for EIKEN, supporting your child, or building confidence for everyday life.
        </p>
        <div class="section-cta">
          <Button href="#consultation">Start Your Learning Journey</Button>
        </div>
      </div>
    </div>
  </Container>
</section>
