---
import Button from "../Button.astro";
import Container from "../Container.astro";
import { business } from "../../data/business";

const { hero } = business.images;
const lessonBadges = [
  "Japanese Lessons",
  "English Lessons",
  "One-on-One Lessons",
  "Japanese Group Classes",
  "Online Learning",
];
---

<section class="hero" id="home" aria-labelledby="hero-title">
  <Container class="hero-grid" size="wide">
    <div class="hero-copy">
      <p class="eyebrow">Online language school</p>
      <h1 id="hero-title">Learn Japanese or English <span>with Confidence</span></h1>
      <p class="hero-lede">
        Personalized online language lessons designed for Filipinos, Japanese learners,
        children, and families.
      </p>
      <p class="hero-support">
        Whether you're preparing for life in Japan, improving your conversational Japanese,
        or studying for EIKEN, iManabu helps you reach your goals through practical, engaging, and
        personalized lessons.
      </p>
      <div class="hero-actions">
        <Button href="#consultation">Book a Free Consultation</Button>
        <Button href="#courses" variant="secondary">View Our Courses</Button>
      </div>
      <ul class="trust-list" aria-label="Available lessons and features">
        {lessonBadges.map((badge) => (
          <li>{badge}</li>
        ))}
      </ul>
    </div>
    <div class="hero-art">
      <img
        class="hero-image"
        src={hero.src}
        alt={hero.alt}
        width={hero.width}
        height={hero.height}
        fetchpriority="high"
      />
    </div>
  </Container>
</section>
