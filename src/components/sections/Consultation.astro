---
import Container from "../Container.astro";
---

<section class="section consultation" id="consultation" aria-labelledby="consultation-title">
  <Container>
    <div class="consultation-grid">
      <div>
        <p class="eyebrow light">Your next step</p>
        <h2 id="consultation-title">Free Japanese Learning Consultation</h2>
        <p class="lead">Not sure where to start? We will help you understand your current level and recommend the best learning path.</p>
        <ul class="check-list light">
          <li>No obligation</li>
          <li>Beginner friendly</li>
          <li>Personal course recommendation</li>
        </ul>
      </div>
      <form class="consultation-form">
        <div class="form-grid">
          <label>Full Name <span>*</span><input name="fullName" autocomplete="name" required /></label>
          <label>Email Address <span>*</span><input type="email" name="email" autocomplete="email" required /></label>
          <label class="full">Preferred Contact Method <span>*</span>
            <select name="contactMethod" required data-contact-method>
              <option value="">Choose a contact method</option>
              <option value="email">Email</option>
              <option value="messenger">Messenger</option>
              <option value="line">LINE</option>
            </select>
          </label>
          <label class="full" data-messenger-field hidden>Facebook Profile Link <span>*</span>
            <input name="facebookProfile" placeholder="https://facebook.com/yourprofile" disabled data-messenger-input />
            <small class="form-helper">If you don't know your Facebook profile link, simply enter your Facebook name and briefly describe your profile picture.</small>
          </label>
          <label>Learning Goal <span>*</span>
            <select name="learningGoal" required>
              <option value="">Choose your learning goal</option>
              <option>Work in Japan</option>
              <option>Daily Conversation</option>
              <option>Travel</option>
              <option>JLPT Preparation</option>
              <option>Support My Child</option>
              <option>Other</option>
            </select>
          </label>
          <label>Current Japanese Level <span>*</span>
            <select name="level" required>
              <option value="">Choose your level</option>
              <option>Beginner</option>
              <option>Elementary</option>
              <option>Intermediate</option>
              <option>Advanced</option>
            </select>
          </label>
          <label class="full">Preferred Schedule<input name="schedule" placeholder="Days and times" /></label>
          <label class="full">Additional Notes<textarea name="notes" rows="4"></textarea></label>
        </div>
        <button class="button button-primary button-md" type="submit">Request My Free Consultation</button>
      </form>
    </div>
  </Container>
</section>

<script>
  const contactMethod = document.querySelector<HTMLSelectElement>('[data-contact-method]');
  const messengerField = document.querySelector<HTMLElement>('[data-messenger-field]');
  const messengerInput = document.querySelector<HTMLInputElement>('[data-messenger-input]');

  const updateMessengerField = () => {
    const showMessengerField = contactMethod?.value === 'messenger';
    messengerField?.toggleAttribute('hidden', !showMessengerField);
    if (messengerInput) {
      messengerInput.disabled = !showMessengerField;
      messengerInput.required = showMessengerField;
    }
  };

  contactMethod?.addEventListener('change', updateMessengerField);
  updateMessengerField();
</script>
