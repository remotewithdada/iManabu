---
import Container from "../Container.astro";
import Button from "../Button.astro";
import { business } from "../../data/business";

const channels = [
  { title: "Email", label: business.contact.email, href: business.contact.emailUrl },
  {
    title: "Facebook Page",
    label: "Visit iManabu on Facebook",
    href: business.contact.facebookUrl,
  },
  {
    title: "Messenger",
    label: business.contact.messengerLabel,
    href: business.contact.messengerUrl,
  },
  {
    title: "LINE",
    label: business.contact.lineLabel,
    href: business.contact.lineUrl,
  },
];
---

<section class="section" id="contact" aria-labelledby="contact-title">
  <Container>
    <div class="section-heading">
      <p class="eyebrow">Contact</p>
      <h2 id="contact-title">Let’s talk about your language goals.</h2>
      <p>Choose the contact method that is most convenient for you.</p>
    </div>
    <div class="contact-grid">
      {channels.map((channel) => (
        <div class="contact-item">
          <span aria-hidden="true">↗</span>
          <div>
            <h3>{channel.title}</h3>
            <p>
              <a href={channel.href} target={channel.title === "Email" ? undefined : "_blank"} rel={channel.title === "Email" ? undefined : "noopener noreferrer"}>
                {channel.label}
              </a>
            </p>
          </div>
        </div>
      ))}
      <div class="contact-item social-placeholders">
        <span aria-hidden="true">•</span>
        <div>
          <h3>More Social Channels</h3>
          {business.socialMedia.map((social) => <p>{social.name}: {social.status}</p>)}
        </div>
      </div>
    </div>
    <div class="section-cta contact-cta">
      <Button href="#consultation">Get Started Today</Button>
    </div>
  </Container>
</section>
