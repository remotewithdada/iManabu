---
import Container from "./Container.astro";
import { business } from "../data/business";

const footerLinks = [
  { label: "About", href: "#about" },
  { label: "Courses", href: "#courses" },
  { label: "Pricing", href: "#pricing" },
  { label: "Testimonials", href: "#testimonials" },
  { label: "FAQ", href: "#faq" },
  { label: "Contact", href: "#contact" },
];

const contactLinks = [
  { label: `Email: ${business.contact.email}`, href: business.contact.emailUrl, external: false },
  { label: "Facebook", href: business.contact.facebookUrl, external: true },
  { label: "Messenger", href: business.contact.messengerUrl, external: true },
  { label: "LINE", href: business.contact.lineUrl, external: true },
];

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <Container class="footer-shell">
    <div class="footer-brand">
      <a class="brand" href="/" aria-label="iManabu home">
        <img
          class="brand-logo brand-logo-footer"
          src="/images/logo2.svg"
          alt="iManabu"
          width="1500"
          height="1500"
        />
      </a>
      <p>
        Japanese lessons, English lessons, and personalized online learning that help every
        student communicate with confidence.
      </p>
    </div>

    <nav class="footer-nav" aria-label="Footer navigation">
      {footerLinks.map((link) => <a href={link.href}>{link.label}</a>)}
    </nav>
    <div class="footer-social" aria-label="Contact information">
      {contactLinks.map((link) => (
        <a
          href={link.href}
          target={link.external ? "_blank" : undefined}
          rel={link.external ? "noopener noreferrer" : undefined}
        >
          {link.label}
        </a>
      ))}
      {business.socialMedia.map((social) => <span>{social.name}: {social.status}</span>)}
    </div>

    <p class="footer-meta">&copy; {year} iManabu. All rights reserved.</p>
  </Container>
</footer>
